{
  "$id": "field-service://schemas/brand",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Brand",
  "description": "Master data entity for manufacturer brands.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1, "description": "Brand name in local language" },
    "nameEn": { "type": "string", "description": "Brand name in English" },
    "logo": { "type": "string", "description": "Brand logo URL" },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Asset categories this brand operates in (e.g., ['hvac', 'appliance'])"
    },
    "website": { "type": "string", "format": "uri" },
    "status": { "type": "string", "enum": ["active", "inactive"], "default": "active" },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "name", "createdAt"]
}
