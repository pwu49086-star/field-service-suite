{
  "$id": "field-service://schemas/solar-asset-extension",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Solar Asset Extension",
  "description": "Solar PV system-specific fields stored in the Asset.extension JSON field.",
  "type": "object",
  "properties": {
    "systemType": { "type": "string", "enum": ["residential", "commercial", "industrial", "utility"] },
    "gridType": { "type": "string", "enum": ["on_grid", "off_grid", "hybrid"] },
    "panelBrand": { "type": "string" },
    "panelModel": { "type": "string" },
    "panelCount": { "type": "integer", "minimum": 1 },
    "panelWattage": { "type": "number", "minimum": 0, "description": "单块功率 (W)" },
    "totalCapacity": { "type": "number", "minimum": 0, "description": "总装机容量 (kWp)" },
    "inverterBrand": { "type": "string" },
    "inverterModel": { "type": "string" },
    "inverterCapacity": { "type": "number", "minimum": 0 },
    "inverterCount": { "type": "integer", "minimum": 1 },
    "hasBattery": { "type": "boolean" },
    "batteryBrand": { "type": "string" },
    "batteryCapacity": { "type": "number", "minimum": 0, "description": "电池容量 (kWh)" },
    "batteryType": { "type": "string", "enum": ["lithium", "lead_acid", "flow"] },
    "gridVoltage": { "type": "integer", "enum": [220, 380] },
    "meterNo": { "type": "string" },
    "installationAngle": { "type": "number" },
    "installationDirection": { "type": "string" },
    "roofType": { "type": "string", "enum": ["flat", "tilted", "ground"] },
    "estimatedAnnualYield": { "type": "number", "description": "预计年发电量 (kWh)" },
    "actualAnnualYield": { "type": "number", "description": "实际年发电量 (kWh)" },
    "performanceRatio": { "type": "number", "minimum": 0, "maximum": 100 },
    "degradationRate": { "type": "number", "minimum": 0 },
    "monitoringPlatform": { "type": "string" },
    "monitoringUrl": { "type": "string" },
    "gridConnectionDate": { "type": "string", "format": "date" },
    "contractNo": { "type": "string" },
    "feedInTariff": { "type": "number", "minimum": 0, "description": "上网电价 (元/kWh)" }
  },
  "required": ["systemType", "gridType", "totalCapacity"]
}
